<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.Relatorio"
             Title="Relatório de Compras">

    <!-- Layout principal da página -->
    <StackLayout Padding="20">

        <!-- Título centralizado -->
        <Label Text="Relatório de Compras Recentes" 
               FontSize="20" 
               HorizontalOptions="Center" />

        <!-- Área para selecionar o período -->
        <HorizontalStackLayout Spacing="10" Margin="0,10,0,10">
            <VerticalStackLayout>
                <Label Text="Data Inicial" />
                <!-- DatePicker vinculado ao campo dtInicio -->
                <DatePicker x:Name="dtInicio" />
            </VerticalStackLayout>

            <VerticalStackLayout>
                <Label Text="Data Final" />
                <!-- DatePicker vinculado ao campo dtFim -->
                <DatePicker x:Name="dtFim" />
            </VerticalStackLayout>

            <!-- Botão que dispara o filtro -->
            <Button Text="Filtrar" Clicked="OnFiltrarClicked" />
        </HorizontalStackLayout>

        <!-- Lista de produtos filtrados -->
        <ListView x:Name="lst_relatorio">

            <!-- Cabeçalho da lista -->
            <ListView.Header>
                <Grid ColumnDefinitions="100,80,80,80,120"
                      BackgroundColor="{StaticResource Gray100}">
                    <Label Grid.Column="0" Text="Descrição" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="Preço" FontAttributes="Bold" />
                    <Label Grid.Column="2" Text="Qnt" FontAttributes="Bold" />
                    <Label Grid.Column="3" Text="Total" FontAttributes="Bold" />
                    <Label Grid.Column="4" Text="Data" FontAttributes="Bold" />
                </Grid>
            </ListView.Header>

            <!-- Template para cada item da lista -->
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Grid ColumnDefinitions="100,80,80,80,120">
                            <!-- Exibe os campos do Produto -->
                            <Label Grid.Column="0" Text="{Binding Descricao}" />
                            <Label Grid.Column="1" Text="{Binding Preco, StringFormat='{}{0:c}'}" />
                            <Label Grid.Column="2" Text="{Binding Quantidade}" />
                            <Label Grid.Column="3" Text="{Binding Total, StringFormat='{}{0:c}'}" />
                            <Label Grid.Column="4" Text="{Binding DataCadastro, StringFormat='{0:dd/MM/yyyy}'}" />
                        </Grid>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </StackLayout>
</ContentPage>